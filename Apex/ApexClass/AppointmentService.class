public class AppointmentService {

    public static void validateDoctorOverload(List<Appointment__c> newAppointments) {

        Set<Id> doctorIds = new Set<Id>();
        Set<Date> apptDates = new Set<Date>();

        for (Appointment__c appt : newAppointments) {
            if (appt.Doctor__c != null && appt.Appointment_Date__c != null) {
                doctorIds.add(appt.Doctor__c);
                apptDates.add(appt.Appointment_Date__c);
            }
        }

        if (doctorIds.isEmpty()) return;

        Map<Id, Doctor__c> doctorMap = new Map<Id, Doctor__c>(
            [SELECT Id, Max_Appointments_Per_Day__c
             FROM Doctor__c
             WHERE Id IN :doctorIds]
        );

        Map<String, Integer> appointmentCount = new Map<String, Integer>();

        for (AggregateResult ar : [
            SELECT Doctor__c docId,
                   Appointment_Date__c adate,
                   COUNT(Id) total
            FROM Appointment__c
            WHERE Doctor__c IN :doctorIds
            AND Appointment_Date__c IN :apptDates
            GROUP BY Doctor__c, Appointment_Date__c
        ]) {
            String key = ar.get('docId') + '_' + ar.get('adate');
            appointmentCount.put(key, (Integer) ar.get('total'));
        }

        for (Appointment__c appt : newAppointments) {
            if (appt.Doctor__c == null || appt.Appointment_Date__c == null) continue;

            Doctor__c doc = doctorMap.get(appt.Doctor__c);
            if (doc == null || doc.Max_Appointments_Per_Day__c == null) continue;

            String key = appt.Doctor__c + '_' + appt.Appointment_Date__c;
            Integer existing = appointmentCount.containsKey(key)
                ? appointmentCount.get(key)
                : 0;

            if (existing >= doc.Max_Appointments_Per_Day__c) {
                appt.addError('Doctor has reached maximum appointments for the day');
            }
        }
    }
}
